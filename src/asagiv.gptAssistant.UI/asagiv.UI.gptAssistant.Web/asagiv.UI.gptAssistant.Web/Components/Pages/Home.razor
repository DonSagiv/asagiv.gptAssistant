@page "/"

<PageTitle>Home</PageTitle>

<style>

    .container {
        position: relative; /* Ensure positioning context for fixed element */
        width: 100%;
        height: 100%; /* Ensure full viewport height */
        margin-bottom: 10px; /* Account for the fixed element's height */
        box-sizing: border-box;
    }

    .fixed-textarea {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100px; /* Adjust height as needed */
        background-color: #f0f0f0; /* Optional background color */
        padding: 10px; /* Add padding for text area */
        box-sizing: border-box;
    }

    .fixed-textarea textarea {
        width: 100%;
        height: 100%;
        margin: 0; /* Override default margin */
        resize: none; /* Prevent resizing */
    }

</style>

<div class="container">

    <div>
        Hello World!
    </div>

    <div class="fixed-textarea">

        <textarea placeholder="Enter a prompt here." />

    </div>

</div>
